@page "/usuarios"

@using Microsoft.AspNetCore.Components.Authorization
@using S_Blazor_TDApp.Shared
@using CurrieTechnologies.Razor.SweetAlert2
@using S_Blazor_TDApp.Client.Services.Interfaces

@* Using para la autorización de usuarios *@
@using Microsoft.AspNetCore.Authorization;
@attribute [Authorize(Roles = "Super_Administrador, Administrador, Supervisor")]


<!-- Page Title -->
<div class="page-title">
    <div class="page-title-icon">
        <i class="bi bi-people-fill"></i>
    </div>
    <div>
        <h3>Administración de Usuarios</h3>
        <span class="page-subtitle">Gestionar cuentas de usuario y permisos</span>
    </div>
</div>

<div class="container-fluid mt-4">
    @if (isLoading)
    {
        <div class="card">
            <div class="card-body table-skeleton">
                @for (int i = 0; i < 5; i++)
                {
                    <div class="skeleton-row">
                        <div class="skeleton skeleton-cell" style="flex: 0.5;"></div>
                        <div class="skeleton skeleton-cell" style="flex: 2;"></div>
                        <div class="skeleton skeleton-cell" style="flex: 1.5;"></div>
                        <div class="skeleton skeleton-badge"></div>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="card shadow">
            <div class="card-header bg-light">
                <div class="row align-items-center">
                    <div class="col">
                        <h5 class="text-primary mb-0">
                            <i class="bi bi-people-fill me-2"></i>Administración de usuarios
                        </h5>
                    </div>
                    <div class="col-auto">
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input type="text" class="form-control" placeholder="Buscar..."
                                   @oninput="OnSearchTermChanged" value="@searchTerm" />
                            @if (!string.IsNullOrEmpty(searchTerm))
                            {
                                <button class="btn btn-outline-secondary" @onclick="ClearSearch">
                                    <i class="bi bi-x"></i>
                                </button>
                            }
                        </div>
                    </div>
                    <AuthorizeView Roles="Super_Administrador, Administrador">
                        <Authorized>
                            <div class="col-auto">
                                <a class="btn btn-success shadow-sm" href="/usuario">
                                    <i class="bi bi-plus-circle me-2"></i>Nuevo
                                </a>
                            </div>
                        </Authorized>
                    </AuthorizeView>
                </div>
            </div>

            @if (listaUsuarios is null || !listaUsuarios.Any())
            {
                <div class="alert alert-info shadow-sm m-3">
                    <i class="bi bi-info-circle me-2"></i>No se encontraron usuarios.
                    <AuthorizeView Roles="Super_Administrador, Administrador">
                        <Authorized> Presione el botón verde <b>"Nuevo"</b> para crearlo.</Authorized>
                    </AuthorizeView>
                </div>
            }
            @if (filteredUsers == null || !filteredUsers.Any())
            {
                <div class="card-body text-center py-5">
                    <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                    <h5 class="mt-3 text-muted">No se encontraron resultados</h5>
                    <p class="text-muted">No hay usuarios registrados o que coincidan con la búsqueda.</p>
                </div>
            }
            else
            {
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Código</th>
                                    <th>Usuario</th>
                                    <th>Nombre</th>
                                    <th>Correo</th>
                                    <th>Rol</th>
                                    <th>Estado</th>
                                    <th>Creación</th>
                                    <th>Actualización</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in pagedUsers)
                                {
                                    <tr>
                                        <td>@item.UsuarioId</td>
                                        <td>@item.Codigo</td>
                                        <td>@item.NombreUsuario</td>
                                        <td>@item.NombreCompleto</td>
                                        <td>@item.Email</td>
                                        <td>@item.Rol?.NombreRol</td>
                                        <td>
                                            <span class="badge bg-@(item.Activo ? "success" : "danger")">
                                                @(item.Activo ? "Habilitado" : "Deshabilitado")
                                            </span>
                                        </td>
                                        <td>@item.FechaCreacion.ToString("dd/MM/yyyy - hh:mm tt")</td>
                                        <td>@(item.FechaActualizacion.HasValue ? item.FechaActualizacion.Value.ToString("dd/MM/yyyy - hh:mm tt") : "Nunca")</td>
                                        <td>
                                            @{
                                                var puedeModificar = PuedeModificar(item);
                                                var tooltipBloqueo = item.UsuarioId == currentUserId
                                                    ? "Edita tus propios datos desde Perfil"
                                                    : "Sin permisos para modificar este usuario";
                                            }
                                            <div class="btn-group" role="group">
                                                @if (puedeModificar)
                                                {
                                                    <a class="btn btn-outline-primary btn-sm" href="/usuario/@item.UsuarioId" title="Editar">
                                                        <i class="bi bi-pencil-fill"></i>
                                                    </a>
                                                    <button type="button" class="btn btn-outline-danger btn-sm"
                                                            @onclick="(() => Eliminar(item.UsuarioId, item.NombreUsuario))" title="Eliminar">
                                                        <i class="bi bi-trash-fill"></i>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <span class="text-muted px-2" title="@tooltipBloqueo">
                                                        <i class="bi bi-lock-fill"></i>
                                                    </span>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <div class="card-footer text-muted">
                <div class="d-flex justify-content-between align-items-center">
                    @if ((filteredUsers?.Count ?? 0) > 10)
                    {
                        <div>
                            <label>Mostrar: </label>
                            <select @onchange="OnPageSizeChanged" value="@pageSize" class="form-select d-inline-block w-auto">
                                @foreach (var option in pageSizeOptions)
                                {
                                    <option value="@option">
                                        @option
                                    </option>
                                }
                            </select>
                            usuarios de @(filteredUsers?.Count ?? 0) en total
                        </div>
                        <div>
                            <button class="btn btn-outline-primary btn-sm" @onclick="PrevPage" disabled="@(currentPage == 1)">Anterior</button>
                            <span class="mx-2">
                                Página @currentPage de @Math.Ceiling((double)(filteredUsers?.Count ?? 0) / pageSize)
                            </span>
                            <button class="btn btn-outline-primary btn-sm" @onclick="NextPage" disabled="@(currentPage * pageSize >= (filteredUsers?.Count ?? 0))">Siguiente</button>
                        </div>
                    }
                    else
                    {
                        <div>
                            <label>
                                <b>@(filteredUsers?.Count ?? 0)</b> registros encontrados. Si hay más de 10, se filtrará y paginará según la cantidad seleccionada.
                            </label>
                        </div>
                    }
                </div>
            </div>
        </div>
        <br />
    }
</div>



