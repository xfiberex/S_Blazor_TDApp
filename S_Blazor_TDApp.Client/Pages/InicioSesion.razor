@page "/"
@layout LoginLayout

@using S_Blazor_TDApp.Shared
@using S_Blazor_TDApp.Client.Extensions
@using S_Blazor_TDApp.Client.Services.Interfaces
@using Microsoft.AspNetCore.Components.Authorization

@inject HttpClient httpClient
@inject NavigationManager navManager
@inject AuthenticationStateProvider autenticacionProvider
@inject IUsuarioService usuarioService

<div class="container min-vh-100 d-flex align-items-center justify-content-center py-4">
    <div class="row w-100 justify-content-center">
        <div class="col-11 col-md-8 col-lg-5">
            <div class="text-center mb-4 fade-in-up">
                <img src="Logo_30x30.png" alt="Logo" width="56" height="56"
                     style="border-radius: 16px; box-shadow: 0 8px 32px rgba(99, 102, 241, 0.3); background: rgba(255,255,255,0.15); padding: 8px;">
                <h4 class="mt-3" style="color: rgba(255,255,255,0.95); font-weight: 700; letter-spacing: -0.5px;">Task Management</h4>
                <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem;">Sistema de Gestión de Tareas</p>
            </div>

            <div class="card border-0 overflow-hidden mx-auto fade-in-up"
                 style="background: rgba(255, 255, 255, 0.08); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.12) !important; box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);">
                <div class="card-header text-white py-3"
                     style="background: linear-gradient(135deg, rgba(99, 102, 241, 0.5), rgba(139, 92, 246, 0.4)) !important; border-bottom: 1px solid rgba(255,255,255,0.1);">
                    <h5 class="mb-0 d-flex align-items-center" style="color: white;">
                        <i class="bi bi-shield-lock me-2" style="color: rgba(255,255,255,0.85);"></i>
                        Inicio de Sesión
                    </h5>
                </div>

                <div class="card-body p-4">
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert d-flex align-items-center mb-3"
                             style="background: rgba(239, 68, 68, 0.15); color: #fca5a5; border: 1px solid rgba(239, 68, 68, 0.2); border-radius: 10px;">
                            <i class="bi bi-exclamation-triangle-fill fs-6 me-2"></i>
                            <div>@errorMessage</div>
                        </div>
                    }

                    <EditForm Model="login" OnValidSubmit="IniciarSesion" Context="editContext">
                        <DataAnnotationsValidator />
                        @if (editContext.GetValidationMessages().Any())
                        {
                            <div class="alert mb-3"
                                 style="background: rgba(239, 68, 68, 0.15); color: #fca5a5; border: 1px solid rgba(239, 68, 68, 0.2); border-radius: 10px;">
                                <h6 class="alert-heading d-flex align-items-center mb-1">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                    Datos necesarios
                                </h6>
                                <ValidationSummary />
                            </div>
                        }

                        <!-- Campo para Correo Electrónico -->
                        <div class="mb-3">
                            <label for="email" class="form-label small mb-1"
                                   style="color: rgba(255,255,255,0.6); font-weight: 500;">Correo Electrónico</label>
                            <div class="input-group"
                                 style="background: rgba(255,255,255,0.06); border-radius: 10px; border: 1px solid rgba(255,255,255,0.1);">
                                <span class="input-group-text"
                                      style="background: transparent; border: none; color: rgba(165, 180, 252, 0.8);">
                                    <i class="bi bi-envelope-fill"></i>
                                </span>
                                <InputText id="email" type="email"
                                           class="form-control"
                                           style="background: transparent; border: none; color: white; box-shadow: none;"
                                           placeholder="ejemplo@dominio.com" @bind-Value="login.Email" />
                            </div>
                        </div>

                        <!-- Campo para Contraseña -->
                        <div class="mb-4">
                            <label for="clave" class="form-label small mb-1"
                                   style="color: rgba(255,255,255,0.6); font-weight: 500;">Contraseña</label>
                            <div class="input-group"
                                 style="background: rgba(255,255,255,0.06); border-radius: 10px; border: 1px solid rgba(255,255,255,0.1);">
                                <span class="input-group-text"
                                      style="background: transparent; border: none; color: rgba(165, 180, 252, 0.8);">
                                    <i class="bi bi-key-fill"></i>
                                </span>
                                <InputText id="clave" type="@(showPassword ? "text" : "password")"
                                           class="form-control"
                                           style="background: transparent; border: none; color: white; box-shadow: none;"
                                           placeholder="Ingrese su contraseña"
                                           @bind-Value="login.Clave" />
                                <button type="button" class="input-group-text"
                                        style="background: transparent; border: none; color: rgba(165, 180, 252, 0.8); cursor: pointer;"
                                        @onclick="TogglePasswordVisibility">
                                    <i class="bi @(showPassword ? "bi-eye-slash-fill" : "bi-eye-fill")"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Botón de envío -->
                        <div class="d-grid gap-2 mt-4">
                            <button type="submit"
                                    class="btn py-2 fw-semibold"
                                    style="background: linear-gradient(135deg, #6366f1, #8b5cf6); color: white; border: none; border-radius: 10px; box-shadow: 0 4px 15px rgba(99,102,241,0.35); transition: all 0.25s ease;"
                                    disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status"
                                          aria-hidden="true"></span>
                                    <span>Iniciando sesión...</span>
                                }
                                else
                                {
                                    <span>Iniciar Sesión</span>
                                }
                            </button>
                        </div>

                        <div class="d-flex justify-content-between mt-3">
                            <a href="/olvide-contrasena" class="text-decoration-none" style="color: rgba(255,255,255,0.6); font-size: 0.85rem; transition: color 0.2s;">
                                ¿Olvidó su contraseña?
                            </a>
                            <a href="/registro" class="text-decoration-none" style="color: rgba(165, 180, 252, 0.9); font-size: 0.85rem; font-weight: 500; transition: color 0.2s;">
                                Crear cuenta
                            </a>
                        </div>
                    </EditForm>
                </div>

                <div class="py-3 text-center" style="background: rgba(0,0,0,0.1); border-top: 1px solid rgba(255,255,255,0.06);">
                    <small style="color: rgba(255,255,255,0.4);">
                        Ingrese sus credenciales para acceder al sistema.
                    </small>
                </div>
            </div>

            <div class="text-center mt-3">
                <small style="color: rgba(255,255,255,0.25); font-size: 0.75rem;">
                    © @DateTime.Now.Year Task Management System. Desarrollado por Ricky Jimenez (fiberex).
                </small>
            </div>
        </div>
    </div>
</div>

@code {
    private EditContext editContext = null!;
    private LoginDTO login = new LoginDTO();
    private bool isSaving = false;
    private string? errorMessage;
    private bool showPassword = false;

    protected override void OnInitialized()
    {
        editContext = new EditContext(login);
    }

    private void TogglePasswordVisibility()
    {
        showPassword = !showPassword;
    }

    private async Task IniciarSesion()
    {
        isSaving = true;
        errorMessage = null;

        try
        {
            var sesionUsuario = await usuarioService.Login(login);

            var autenticacionExt = (AutenticacionExtension)autenticacionProvider;
            await autenticacionExt.ActualizarEstadoAutenticacion(sesionUsuario);
            navManager.NavigateTo("/registroProcesos");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Console.WriteLine($"Error en inicio de sesión: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    public class ErrorResponse
    {
        public string Message { get; set; } = string.Empty;
    }
}