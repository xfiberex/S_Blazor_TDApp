@page "/olvide-contrasena"
@layout LoginLayout

@using S_Blazor_TDApp.Shared
@using S_Blazor_TDApp.Client.Services.Interfaces
@using System.ComponentModel.DataAnnotations

@inject IUsuarioService usuarioService
@inject NavigationManager navManager

<div class="container min-vh-100 d-flex align-items-center justify-content-center py-4">
    <div class="row w-100 justify-content-center">
        <div class="col-11 col-md-8 col-lg-5">
            <div class="text-center mb-4 fade-in-up">
                <img src="Logo_30x30.png" alt="Logo" width="56" height="56"
                     style="border-radius: 16px; box-shadow: 0 8px 32px rgba(99, 102, 241, 0.3); background: rgba(255,255,255,0.15); padding: 8px;">
                <h4 class="mt-3" style="color: rgba(255,255,255,0.95); font-weight: 700; letter-spacing: -0.5px;">Task Management</h4>
                <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem;">Recuperación de Contraseña</p>
            </div>

            <div class="card border-0 overflow-hidden mx-auto fade-in-up"
                 style="background: rgba(255, 255, 255, 0.08); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.12) !important; box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);">
                <div class="card-header text-white py-3"
                     style="background: linear-gradient(135deg, rgba(99, 102, 241, 0.5), rgba(139, 92, 246, 0.4)) !important; border-bottom: 1px solid rgba(255,255,255,0.1);">
                    <h5 class="mb-0 d-flex align-items-center" style="color: white;">
                        <i class="bi bi-key-fill me-2" style="color: rgba(255,255,255,0.85);"></i>
                        Olvidé mi Contraseña
                    </h5>
                </div>

                <div class="card-body p-4">
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert d-flex align-items-center mb-3"
                             style="background: rgba(239, 68, 68, 0.15); color: #fca5a5; border: 1px solid rgba(239, 68, 68, 0.2); border-radius: 10px;">
                            <i class="bi bi-exclamation-triangle-fill fs-6 me-2"></i>
                            <div>@errorMessage</div>
                        </div>
                    }

                    @if (envioExitoso)
                    {
                        <div class="alert d-flex align-items-center mb-3"
                             style="background: rgba(16, 185, 129, 0.15); color: #6ee7b7; border: 1px solid rgba(16, 185, 129, 0.2); border-radius: 10px;">
                            <i class="bi bi-check-circle-fill fs-6 me-2"></i>
                            <div>@mensajeExito</div>
                        </div>
                        <div class="text-center mt-4">
                            <a href="/" class="btn btn-outline-light px-4 py-2" style="border-radius: 10px;">Volver al Inicio</a>
                        </div>
                    }
                    else
                    {
                        <p style="color: rgba(255,255,255,0.8); font-size: 0.9rem;" class="mb-4 text-center">
                            Ingrese su correo electrónico y le enviaremos un enlace para restablecer su contraseña.
                        </p>

                        <EditForm Model="modelo" OnValidSubmit="EnviarCorreoRecuperacion">
                            <DataAnnotationsValidator />

                            <div class="mb-4">
                                <label class="form-label" style="color: rgba(255,255,255,0.7); font-size: 0.85rem; font-weight: 500;">Correo Electrónico</label>
                                <div class="input-group">
                                    <span class="input-group-text border-0" style="background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.6);">
                                        <i class="bi bi-envelope"></i>
                                    </span>
                                    <InputText @bind-Value="modelo.Correo" class="form-control border-0 text-white"
                                               style="background: rgba(255,255,255,0.05); box-shadow: none;"
                                               placeholder="ejemplo@correo.com" />
                                </div>
                                <ValidationMessage For="@(() => modelo.Correo)" class="text-danger mt-1" style="font-size: 0.8rem;" />
                            </div>

                            <button type="submit" class="btn w-100 py-2 fw-semibold mb-3"
                                    disabled="@isSubmitting"
                                    style="background: linear-gradient(135deg, #6366f1, #8b5cf6); color: white; border: none; border-radius: 10px; box-shadow: 0 4px 15px rgba(99,102,241,0.35); transition: all 0.3s ease;">
                                @if (isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>Enviando...</span>
                                }
                                else
                                {
                                    <span>Enviar Enlace</span>
                                }
                            </button>

                            <div class="text-center mt-3">
                                <a href="/" class="text-decoration-none" style="color: rgba(255,255,255,0.6); font-size: 0.85rem; transition: color 0.2s;">
                                    <i class="bi bi-arrow-left me-1"></i> Volver al inicio de sesión
                                </a>
                            </div>
                        </EditForm>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private OlvideContrasenaModel modelo = new();
    private bool isSubmitting = false;
    private bool envioExitoso = false;
    private string? errorMessage;
    private string? mensajeExito;

    private async Task EnviarCorreoRecuperacion()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            var request = new OlvideContrasenaDTO { Email = modelo.Correo };
            mensajeExito = await usuarioService.OlvideContrasena(request) ? "Se ha enviado un enlace de recuperación a su correo." : "Error al enviar el correo.";
            envioExitoso = true;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class OlvideContrasenaModel
    {
        [Required(ErrorMessage = "El correo es requerido")]
        [EmailAddress(ErrorMessage = "Formato de correo inválido")]
        public string Correo { get; set; } = string.Empty;
    }
}
