@page "/restablecer-contrasena"
@layout LoginLayout

@using S_Blazor_TDApp.Shared
@using S_Blazor_TDApp.Client.Services.Interfaces
@using System.ComponentModel.DataAnnotations

@inject IUsuarioService usuarioService
@inject NavigationManager navManager

<div class="container min-vh-100 d-flex align-items-center justify-content-center py-4">
    <div class="row w-100 justify-content-center">
        <div class="col-11 col-md-8 col-lg-5">
            <div class="text-center mb-4 fade-in-up">
                <img src="Logo_30x30.png" alt="Logo" width="56" height="56"
                     style="border-radius: 16px; box-shadow: 0 8px 32px rgba(99, 102, 241, 0.3); background: rgba(255,255,255,0.15); padding: 8px;">
                <h4 class="mt-3" style="color: rgba(255,255,255,0.95); font-weight: 700; letter-spacing: -0.5px;">Task Management</h4>
                <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem;">Restablecer Contraseña</p>
            </div>

            <div class="card border-0 overflow-hidden mx-auto fade-in-up"
                 style="background: rgba(255, 255, 255, 0.08); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.12) !important; box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);">
                <div class="card-header text-white py-3"
                     style="background: linear-gradient(135deg, rgba(99, 102, 241, 0.5), rgba(139, 92, 246, 0.4)) !important; border-bottom: 1px solid rgba(255,255,255,0.1);">
                    <h5 class="mb-0 d-flex align-items-center" style="color: white;">
                        <i class="bi bi-shield-lock-fill me-2" style="color: rgba(255,255,255,0.85);"></i>
                        Nueva Contraseña
                    </h5>
                </div>

                <div class="card-body p-4">
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert d-flex align-items-center mb-3"
                             style="background: rgba(239, 68, 68, 0.15); color: #fca5a5; border: 1px solid rgba(239, 68, 68, 0.2); border-radius: 10px;">
                            <i class="bi bi-exclamation-triangle-fill fs-6 me-2"></i>
                            <div>@errorMessage</div>
                        </div>
                    }

                    @if (restablecimientoExitoso)
                    {
                        <div class="alert d-flex align-items-center mb-3"
                             style="background: rgba(16, 185, 129, 0.15); color: #6ee7b7; border: 1px solid rgba(16, 185, 129, 0.2); border-radius: 10px;">
                            <i class="bi bi-check-circle-fill fs-6 me-2"></i>
                            <div>@mensajeExito</div>
                        </div>
                        <div class="text-center mt-4">
                            <a href="/" class="btn py-2 fw-semibold w-100" style="background: linear-gradient(135deg, #6366f1, #8b5cf6); color: white; border: none; border-radius: 10px; box-shadow: 0 4px 15px rgba(99,102,241,0.35);">
                                Iniciar Sesión
                            </a>
                        </div>
                    }
                    else if (string.IsNullOrEmpty(Token) || string.IsNullOrEmpty(Email))
                    {
                        <div class="alert d-flex align-items-center mb-3"
                             style="background: rgba(239, 68, 68, 0.15); color: #fca5a5; border: 1px solid rgba(239, 68, 68, 0.2); border-radius: 10px;">
                            <i class="bi bi-exclamation-triangle-fill fs-6 me-2"></i>
                            <div>Enlace de restablecimiento inválido o incompleto.</div>
                        </div>
                        <div class="text-center mt-4">
                            <a href="/" class="btn btn-outline-light px-4 py-2" style="border-radius: 10px;">Volver al Inicio</a>
                        </div>
                    }
                    else
                    {
                        <EditForm Model="modelo" OnValidSubmit="Restablecer">
                            <DataAnnotationsValidator />

                            <div class="mb-3">
                                <label class="form-label" style="color: rgba(255,255,255,0.7); font-size: 0.85rem; font-weight: 500;">Nueva Contraseña</label>
                                <div class="input-group">
                                    <span class="input-group-text border-0" style="background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.6);">
                                        <i class="bi bi-lock"></i>
                                    </span>
                                    <InputText @bind-Value="modelo.NuevaContrasena" type="password" class="form-control border-0 text-white"
                                               style="background: rgba(255,255,255,0.05); box-shadow: none;"
                                               placeholder="********" />
                                </div>
                                <ValidationMessage For="@(() => modelo.NuevaContrasena)" class="text-danger mt-1" style="font-size: 0.8rem;" />
                            </div>

                            <div class="mb-4">
                                <label class="form-label" style="color: rgba(255,255,255,0.7); font-size: 0.85rem; font-weight: 500;">Confirmar Contraseña</label>
                                <div class="input-group">
                                    <span class="input-group-text border-0" style="background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.6);">
                                        <i class="bi bi-lock-fill"></i>
                                    </span>
                                    <InputText @bind-Value="modelo.ConfirmarContrasena" type="password" class="form-control border-0 text-white"
                                               style="background: rgba(255,255,255,0.05); box-shadow: none;"
                                               placeholder="********" />
                                </div>
                                <ValidationMessage For="@(() => modelo.ConfirmarContrasena)" class="text-danger mt-1" style="font-size: 0.8rem;" />
                            </div>

                            <button type="submit" class="btn w-100 py-2 fw-semibold mb-3"
                                    disabled="@isSubmitting"
                                    style="background: linear-gradient(135deg, #6366f1, #8b5cf6); color: white; border: none; border-radius: 10px; box-shadow: 0 4px 15px rgba(99,102,241,0.35); transition: all 0.3s ease;">
                                @if (isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>Guardando...</span>
                                }
                                else
                                {
                                    <span>Restablecer Contraseña</span>
                                }
                            </button>
                        </EditForm>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Token { get; set; }

    [SupplyParameterFromQuery]
    public string? Email { get; set; }

    private RestablecerContrasenaModel modelo = new();
    private bool isSubmitting = false;
    private bool restablecimientoExitoso = false;
    private string? errorMessage;
    private string? mensajeExito;

    private async Task Restablecer()
    {
        if (string.IsNullOrEmpty(Token) || string.IsNullOrEmpty(Email))
        {
            errorMessage = "Faltan parámetros para restablecer la contraseña.";
            return;
        }

        isSubmitting = true;
        errorMessage = null;

        try
        {
            var request = new RestablecerContrasenaDTO
            {
                Token = Token,
                Email = Email,
                NuevaClave = modelo.NuevaContrasena
            };
            var exito = await usuarioService.RestablecerContrasena(request);
            if (exito)
            {
                mensajeExito = "Contraseña restablecida correctamente.";
                restablecimientoExitoso = true;
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class RestablecerContrasenaModel
    {
        [Required(ErrorMessage = "La contraseña es requerida")]
        [StringLength(100, MinimumLength = 6, ErrorMessage = "La contraseña debe tener al menos 6 caracteres")]
        public string NuevaContrasena { get; set; } = string.Empty;

        [Required(ErrorMessage = "Debe confirmar la contraseña")]
        [Compare("NuevaContrasena", ErrorMessage = "Las contraseñas no coinciden")]
        public string ConfirmarContrasena { get; set; } = string.Empty;
    }
}
