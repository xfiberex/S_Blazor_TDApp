@using Microsoft.AspNetCore.Components.Authorization
@using Blazored.SessionStorage
@using S_Blazor_TDApp.Client.Extensions
@using S_Blazor_TDApp.Client.Services
@using S_Blazor_TDApp.Shared

@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject ISessionStorageService SessionStorage
@inject MenuPermisoEstado MenuEstado

<div class="bg-dark text-light h-100 d-flex flex-column @(Collapse ? "nav-collapsed" : "")">
    <div class="top-row navbar navbar-dark">
        <div class="container-fluid px-4">
            <a class="navbar-brand" href="registroProcesos">
                <img src="/Logo_30x30.png" alt="L" width="30" height="30" class="textIcon me-2 rounded-image">
                @if (!Collapse)
                {
                    <span class="brand-text">Task Management</span>
                }
            </a>
            <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenuMobile">
                <span class="navbar-toggler-icon"></span>
            </button>
        </div>
    </div>

    <div class="@GetNavMenuCssClass() nav-scrollable">
        <nav class="flex-column">

            @* ── SECCIÓN GESTIÓN ──────────────────────────────────── *@
            @if (MostrarSeccionGestion)
            {
                <span class="nav-section-label">GESTIÓN</span>

                @if (MenuEstado.TieneAcceso("registroProcesos"))
                {
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="registroProcesos" Match="NavLinkMatch.All">
                            <i aria-hidden="true" class="bi bi-house-gear-fill"></i>
                            <span class="nav-label">Procesos</span>
                        </NavLink>
                    </div>
                }

                @if (MenuEstado.TieneAcceso("tareasRecurrentes"))
                {
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="tareasRecurrentes">
                            <i aria-hidden="true" class="bi bi-list-task"></i>
                            <span class="nav-label">Recurrentes</span>
                        </NavLink>
                    </div>
                }

                @if (MenuEstado.TieneAcceso("tareasDias"))
                {
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="tareasDias">
                            <i aria-hidden="true" class="bi bi-calendar3"></i>
                            <span class="nav-label">Disponibilidad</span>
                        </NavLink>
                    </div>
                }

                @if (MenuEstado.TieneAcceso("tareasCalendario"))
                {
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="tareasCalendario">
                            <i aria-hidden="true" class="bi bi-calendar2-range-fill"></i>
                            <span class="nav-label">Calendario</span>
                        </NavLink>
                    </div>
                }
            }

            @* ── SECCIÓN ADMINISTRACIÓN ───────────────────────────── *@
            @if (MostrarSeccionAdministracion)
            {
                <span class="nav-section-label">ADMINISTRACIÓN</span>

                @if (MenuEstado.TieneAcceso("usuarios"))
                {
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="usuarios">
                            <i aria-hidden="true" class="bi bi-people-fill"></i>
                            <span class="nav-label">Usuarios</span>
                        </NavLink>
                    </div>
                }

                @if (MenuEstado.TieneAcceso("rolesPermisos"))
                {
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="rolesPermisos">
                            <i aria-hidden="true" class="bi bi-person-fill-gear"></i>
                            <span class="nav-label">Roles y Permisos</span>
                        </NavLink>
                    </div>
                }
            }

            <!-- Botón para colapsar/expandir el sidebar - solo visible en desktop -->
            <div class="nav-item px-3 mt-auto desktop-only">
                <span class="nav-link toggle-link" title="Toggle sidebar" @onclick="ToggleNavMenu">
                    <i aria-hidden="true" class="bi @(Collapse ? "bi-arrow-bar-right" : "bi-arrow-bar-left")"></i>
                    <span class="nav-label">@(Collapse ? "Expandir" : "Contraer")</span>
                </span>
            </div>
        </nav>
    </div>
</div>

@code {
    [Parameter]
    public bool Collapse { get; set; }

    [Parameter]
    public EventCallback<bool> CollapseChanged { get; set; }

    // Variable para controlar el estado del menú móvil
    private bool mobileMenuCollapsed = true;

    // Rutas de cada sección para calcular visibilidad de etiquetas
    private static readonly string[] RutasGestion = { "registroProcesos", "tareasRecurrentes", "tareasDias", "tareasCalendario" };
    private static readonly string[] RutasAdministracion = { "usuarios", "rolesPermisos" };

    private bool MostrarSeccionGestion => RutasGestion.Any(r => MenuEstado.TieneAcceso(r));
    private bool MostrarSeccionAdministracion => RutasAdministracion.Any(r => MenuEstado.TieneAcceso(r));

    // Método para obtener la clase CSS del menú
    private string GetNavMenuCssClass() =>
        mobileMenuCollapsed ? "collapse" : string.Empty;

    private void ToggleNavMenu()
    {
        Collapse = !Collapse;
        CollapseChanged.InvokeAsync(Collapse);
    }

    private void ToggleNavMenuMobile()
    {
        mobileMenuCollapsed = !mobileMenuCollapsed;
    }

    // Se registra el listener de resize y se cargan los menús al inicializar
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("addResizeListener", DotNetObjectReference.Create(this));
            await CargarMenusPermitidos();
        }
    }

    private async Task CargarMenusPermitidos()
    {
        try
        {
            var sesion = await SessionStorage.ObtenerStorage<InicioSesionDTO>("sesionUsuario");
            if (sesion != null && sesion.RolId > 0)
            {
                await MenuEstado.ObtenerMenusPermitidos(sesion.RolId);
                StateHasChanged();
            }
        }
        catch
        {
            // Si falla la carga de permisos, el NavMenu no mostrará menús.
            // El usuario puede recargar o volver a iniciar sesión.
        }
    }

    // Método invocable desde JavaScript cuando se produce un cambio de tamaño
    [JSInvokable]
    public Task OnResize(int width)
    {
        // Umbral para considerar que es vista móvil (por ejemplo, menor a 768px)
        if (width < 768 && Collapse)
        {
            Collapse = false;
            CollapseChanged.InvokeAsync(Collapse);
            StateHasChanged();
        }
        return Task.CompletedTask;
    }
}